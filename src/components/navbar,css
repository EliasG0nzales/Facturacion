}

.menu-container {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Estilo de los botones del menú */
.dropbtn {
  background: none;
  border: none;
  color: white;
  font-weight: 600;
  font-size: 15px;
  cursor: pointer;
  padding: 10px;
}

/* Dropdown logic */
.dropdown {
  position: relative;
  display: inline-block;
}

.dropdown-content {
  display: none;
  position: absolute;
  background-color: white;
  min-width: 200px;
  box-shadow: 0px 8px 16px rgba(0,0,0,0.2);
  z-index: 100;
  border-radius: 4px;
  margin-top: 5px;
}

.dropdown-content a {
  color: #333;
  padding: 12px 16px;
  text-decoration: none;
  display: block;
  font-size: 14px;
}

.dropdown-content a:hover {
  background-color: #f1f1f1;
}

.dropdown:hover .dropdown-content {
  display: block;
}

/* BOTÓN DE ALERTA ROJO IGUAL A LA IMAGEN */
.alerta-roja {
  background-color: #FF0000;
  color: white;
  padding: 8px 15px;
  border-radius: 5px;
  font-weight: bold;
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 5px;
}

.alerta-roja:hover {
  background-color: #d60000;
}

/* Info de usuario y salir */
.user-info {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  border-left: 1px solid rgba(255,255,255,0.3);
  padding-left: 15px;
}

.logout-btn {
  background: none;
  border: none;
  color: white;
  font-size: 20px;
  cursor: pointer;
}